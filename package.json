{
  "name": "poe-trade-plus",
  "displayName": "Poe Trade Plus",
  "version": "1.0.74",
  "license": "MIT",
  "description": "Poe Trade Plus enhances the Path of Exile trade site with bookmarks, history and result tools.",
  "author": "KroxiLabs",
  "contributors": [
    "louisgv",
    "joacoesteban"
  ],
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "node scripts/wxt-firefox-dev.cjs",
    "build:chrome": "node scripts/wxt-runner.cjs build",
    "build:firefox": "node scripts/wxt-runner.cjs build -b firefox",
    "build": "npm run build:chrome && npm run build:firefox",
    "version:bump": "node scripts/bump-version.cjs",
    "zip:chrome": "node scripts/wxt-runner.cjs zip",
    "zip:firefox": "node scripts/wxt-runner.cjs zip -b firefox",
    "package:chrome": "npm run zip:chrome",
    "package:firefox": "npm run zip:firefox",
    "package": "npm run version:bump && npm run package:chrome && npm run package:firefox",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "js-base64": "^3.7.8",
    "lucide-static": "^1.18.0",
    "svelte": "^5.56.3",
    "svelte-preprocess": "6.0.5",
    "svgo": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/chrome": "0.1.43",
    "@types/node": "25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@wxt-dev/module-svelte": "^2.0.5",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "prettier": "3.8.4",
    "sass-embedded": "^1.100.0",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.26"
  },
  "overrides": {
    "content-security-policy-parser": "0.6.0",
    "msgpackr": "^1.11.9"
  },
  "sass": {
    "silenceDeprecations": [
      "legacy-js-api"
    ]
  }
}
